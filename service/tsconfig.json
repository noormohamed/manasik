{
  "compilerOptions": {
    "target": "ES6",
    "module": "CommonJS",
    "outDir": "./dist",
    "rootDir": "./src",
    "strict": false,
    "esModuleInterop": true,
    "skipLibCheck": true,
    "forceConsistentCasingInFileNames": true,
    "noImplicitAny": false
  },
  "include": ["src", "src/types", "src/typing", "knexfile.ts"],
  "exclude": [
    "node_modules",
    "src/__tests__/**",
    "src/services/elastic.ts",
    "src/services/llama3.ts",
    "src/services/freshworks/**",
    "src/services/payments/**",
    "src/services/email/**",
    "src/utils/ip.ts"
  ],
  "ts-node": {
    "transpileOnly": true,
    "files": true
  }
}
