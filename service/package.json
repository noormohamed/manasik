{
  "name": "booking-platform-service",
  "version": "1.0.0",
  "description": "Multi-service booking platform backend",
  "main": "dist/server.js",
  "scripts": {
    "dev": "nodemon --exec ts-node src/server.ts",
    "build": "tsc",
    "start": "node dist/server.js",
    "test": "jest --detectOpenHandles",
    "test:watch": "jest --watch",
    "test:coverage": "jest --coverage",
    "lint": "eslint src --ext .ts",
    "format": "prettier --write \"src/**/*.ts\"",
    "db:start": "docker-compose up -d",
    "db:stop": "docker-compose down",
    "db:logs": "docker-compose logs -f mysql",
    "migrate:latest": "ts-node node_modules/.bin/knex --knexfile knexfile.ts migrate:latest",
    "migrate:rollback": "ts-node node_modules/.bin/knex --knexfile knexfile.ts migrate:rollback",
    "migrate:status": "ts-node node_modules/.bin/knex --knexfile knexfile.ts migrate:status",
    "migrate:make": "ts-node node_modules/.bin/knex --knexfile knexfile.ts migrate:make"
  },
  "keywords": [
    "booking",
    "platform",
    "hotel",
    "taxi",
    "experience"
  ],
  "author": "",
  "license": "MIT",
  "dependencies": {
    "@koa/cors": "^5.0.0",
    "aws-sdk": "^2.1500.0",
    "axios": "^1.15.0",
    "bcryptjs": "^2.4.3",
    "dotenv": "^16.3.1",
    "jsonwebtoken": "^9.0.2",
    "knex": "^3.2.9",
    "koa": "^2.14.2",
    "koa-bodyparser": "^4.4.1",
    "koa-cors": "^0.0.16",
    "koa-helmet": "^7.0.2",
    "koa-router": "^12.0.0",
    "mysql2": "^3.6.5",
    "nodemailer": "^8.0.5",
    "otplib": "^12.0.1",
    "uuid": "^9.0.1",
    "zod": "^3.22.4"
  },
  "devDependencies": {
    "@types/bcryptjs": "^2.4.6",
    "@types/jest": "^29.5.11",
    "@types/jsonwebtoken": "^9.0.7",
    "@types/koa": "^2.13.11",
    "@types/koa-router": "^7.4.8",
    "@types/node": "^20.10.6",
    "@types/nodemailer": "^8.0.0",
    "@types/supertest": "^6.0.2",
    "@types/uuid": "^9.0.7",
    "@typescript-eslint/eslint-plugin": "^6.17.0",
    "@typescript-eslint/parser": "^6.17.0",
    "eslint": "^8.56.0",
    "fast-check": "^4.7.0",
    "jest": "^29.7.0",
    "nodemon": "^3.0.2",
    "prettier": "^3.1.1",
    "supertest": "^6.3.3",
    "ts-jest": "^29.1.1",
    "ts-node": "^10.9.2",
    "typescript": "^5.3.3"
  }
}
