# Server Configuration
NODE_ENV=development
PORT=3001

# Database Configuration
DB_HOST=localhost
DB_PORT=3306
DB_USER=booking_user
DB_PASSWORD=booking_password
DB_NAME=booking_platform

# JWT Configuration
JWT_SECRET=your-secret-key-change-in-production
JWT_REFRESH_SECRET=your-refresh-secret-key-change-in-production
JWT_EXPIRY=24h
JWT_REFRESH_EXPIRY=7d
SIGNING_SECRET=your-signing-secret-key-change-in-production

# CORS Configuration
CORS_ORIGIN=http://localhost:3000

# Feature Flags - API Endpoints (true/false)
ENABLE_AUTH_ENDPOINTS=true
ENABLE_USER_ENDPOINTS=true
ENABLE_HOTEL_ENDPOINTS=true
ENABLE_CHECKOUT_ENDPOINTS=true

# Feature Flags - Auth Methods
ENABLE_REGISTRATION=true
ENABLE_LOGIN=true
ENABLE_REFRESH_TOKEN=true
ENABLE_GUEST_CHECKOUT=true

# Feature Flags - Hotel Features
ENABLE_HOTEL_LISTING=true
ENABLE_HOTEL_DETAILS=true
ENABLE_ROOM_AVAILABILITY=true
ENABLE_HOTEL_BOOKING=true

# Feature Flags - Checkout Features
ENABLE_CHECKOUT_SESSION=true
ENABLE_CHECKOUT_ITEMS=true
ENABLE_CHECKOUT_DISCOUNT=true
ENABLE_CHECKOUT_CONVERSION=true
ENABLE_CHECKOUT_COMPLETE=true

# SMTP Email Configuration
# Works with any provider: Mailtrap, SendGrid, Mailgun, Gmail, etc.
SMTP_HOST=sandbox.smtp.mailtrap.io
SMTP_PORT=2525
SMTP_USER=your-smtp-user
SMTP_PASS=your-smtp-password
SMTP_FROM=noreply@manasik.com
SMTP_SECURE=false

FRONTEND_URL=http://localhost:3000

# Stripe Configuration
STRIPE_BASE_URL=https://api.stripe.com/v1
STRIPE_SECRET_KEY=your-stripe-secret-key
STRIPE_PUBLISHABLE_KEY=your-stripe-publishable-key

# Wasabi S3 Configuration
WASABI_ACCESS_KEY_ID=your-wasabi-access-key
WASABI_SECRET_ACCESS_KEY=your-wasabi-secret-key
WASABI_ENDPOINT=https://s3.eu-west-1.wasabisys.com
