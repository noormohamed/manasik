FROM node:18-alpine

WORKDIR /app

# Copy package files
COPY package*.json ./

# Install all dependencies
RUN npm ci

# Copy next config and tsconfig (needed for Next.js)
COPY next.config.js tsconfig.json ./

# Don't copy src - it will be mounted as a volume

# Expose Next.js dev server port
EXPOSE 3000

# Run Next.js dev server
CMD ["npm", "run", "dev"]
