FROM node:20-alpine

WORKDIR /app

# Copy package files
COPY package*.json ./

# Install dependencies
RUN npm install

# Copy the rest of the application
COPY . .

# Expose port
EXPOSE 3000

# Set environment for development
ENV NODE_ENV=development
ENV WATCHPACK_POLLING=true

# Use ENTRYPOINT so CMD can be overridden
ENTRYPOINT ["npm", "run"]
CMD ["dev"]
